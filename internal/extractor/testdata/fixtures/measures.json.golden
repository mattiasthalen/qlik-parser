  {
    "id": "NRJqDL",
    "label": "Task Children",
    "def": "Count({\u003cTaskChildID1={\"=Len(TaskChildID1)\u003e=1\"}\u003e}DISTINCT TaskChildID1) \r\n+ Count({\u003cTaskChildID2={\"=Len(TaskChildID1)\u003e=2\"}\u003e}DISTINCT TaskChildID2) \n+ Count({\u003cTaskChildID3={\"=Len(TaskChildID3)\u003e=1\"}\u003e}DISTINCT TaskChildID3) \n+ Count({\u003cTaskChildID4={\"=Len(TaskChildID4)\u003e=1\"}\u003e}DISTINCT TaskChildID4) \n+ Count({\u003cTaskChildID5={\"=Len(TaskChildID5)\u003e=1\"}\u003e}DISTINCT TaskChildID5)\n+ Count({\u003cTaskChildID6={\"=Len(TaskChildID6)\u003e=1\"}\u003e}DISTINCT TaskChildID6) \n+ Count({\u003cTaskChildID7={\"=Len(TaskChildID7)\u003e=1\"}\u003e}DISTINCT TaskChildID7) \n+ Count({\u003cTaskChildID8={\"=Len(TaskChildID8)\u003e=1\"}\u003e}DISTINCT TaskChildID8) \n+ Count({\u003cTaskChildID9={\"=Len(TaskChildID9)\u003e=1\"}\u003e}DISTINCT TaskChildID9) \n+ Count({\u003cTaskChildID10={\"=Len(TaskChildID10)\u003e=1\"}\u003e}DISTINCT TaskChildID10)",
    "tags": [],
    "description": ""
  },
